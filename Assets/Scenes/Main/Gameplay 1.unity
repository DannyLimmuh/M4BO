      objectReference: {fileID: 0}
    - target: {fileID: 4324414968805823158, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: m_LocalEulerAnglesHint.z
      value: 180
      objectReference: {fileID: 0}
    - target: {fileID: 6858051702242804624, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: m_Texture
      value: 
      objectReference: {fileID: 2800000, guid: afac4838edad3964793af28e5a61a72c, type: 3}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: dialogue.Array.size
      value: 20
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[0]'
      value: '''What do you know about disappearances during the lunar festival?'''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[1]'
      value: '''''you''re talking about the thumping.... aren''t you?'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[2]'
      value: '''''I''ve heard it every lunar year since I started working here 9
        years ago'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[3]'
      value: '''''But 6 years ago, something even stranger happened'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[4]'
      value: '''''I was locking up the school'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[5]'
      value: '''''And heard that thumping again.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[6]'
      value: '''''I saw a student standing In front one of the classroom doors.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[7]'
      value: '''''I called out to them to ask '''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[8]'
      value: ''''' why the hell they were still at school at this hour?'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[9]'
      value: '''''The student didn''t answer and walked into the classroom'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[10]'
      value: '''''Then the thumping stopped.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[11]'
      value: '''''I went in right after that'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[12]'
      value: '''''The room was empty...'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[13]'
      value: '''''No student, nobody.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[14]'
      value: '''''I reported it to the police that same night'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[15]'
      value: '''''They said i must''ve imaged it'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[16]'
      value: '''''The next day a student was reported missing...'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[17]'
      value: '''''What was their name again?'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[18]'
      value: '''''I have no clue what happened that night.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[19]'
      value: '"I''m not crazy...I know what I saw."'
      objectReference: {fileID: 0}
    m_RemovedComponents: []
    m_RemovedGameObjects: []
    m_AddedGameObjects: []
    m_AddedComponents: []
  m_SourcePrefab: {fileID: 100100000, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
