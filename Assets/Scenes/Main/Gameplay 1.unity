      propertyPath: m_LocalEulerAnglesHint.z
      value: 180
      objectReference: {fileID: 0}
    - target: {fileID: 6858051702242804624, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: m_Texture
      value: 
      objectReference: {fileID: 2800000, guid: 3ae823a96deabb34b8bd44bf3439c69b, type: 3}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: dialogue.Array.size
      value: 14
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[0]'
      value: What do you know about disappearances during the lunar festival?
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[1]'
      value: The teacher hesitated before answering
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[2]'
      value: '''''Okay but you didn''t hear this from me.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[3]'
      value: '''''During lunar year, i think it was a few years ago'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[4]'
      value: '''''I was supervising some students in the courtyard'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[5]'
      value: '''''I looked up at one of the classrooms '''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[6]'
      value: '''''and saw someone standing inside wearing a bunny mask.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[7]'
      value: '''''I remember for some reason feeling uneasy.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[8]'
      value: '''''I looked away for a moment to help a student '''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[9]'
      value: '''''When I looked back the masked person was gone.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[10]'
      value: '''''The next day a student was reported missing.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[11]'
      value: '''''I can''t prove the two things were connected'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[12]'
      value: '''''But I can''t help checking that window every year.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[13]'
      value: '''''Sometimes i think i still see someone standing there.'''''
      objectReference: {fileID: 0}
    m_RemovedComponents: []
    m_RemovedGameObjects: []
    m_AddedGameObjects: []
    m_AddedComponents: []
  m_SourcePrefab: {fileID: 100100000, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
