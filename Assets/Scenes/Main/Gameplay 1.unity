    - target: {fileID: 4324414968805823158, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: m_LocalEulerAnglesHint.y
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 4324414968805823158, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: m_LocalEulerAnglesHint.z
      value: 180
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: dialogue.Array.size
      value: 12
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[0]'
      value: What do you know about disappearances during the lunar festival?
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[1]'
      value: "''I\u2019ve heard about the legend that every year a student goes missing.''"
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[2]'
      value: "''I don't think it\u2019s a legend, I think someone is trying to cover
        something up.''"
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[3]'
      value: '''''2 years ago. During the festival I forgot my backpack at school.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[4]'
      value: '''''So, I snuck in and quickly grab it.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[5]'
      value: '''''But i heard a strange noise coming from a classroom.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[6]'
      value: '''''Almost like thumping noises.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[7]'
      value: '''''And I heard someone talking.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[8]'
      value: '''''I thought it was a teacher, so I quickly left school.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[9]'
      value: '''''The next day student was reported missing.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[10]'
      value: '''''I sometimes still wonder who I heard talking in that classroom.'''''
      objectReference: {fileID: 0}
    - target: {fileID: 7847626929346836500, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
      propertyPath: 'dialogue.Array.data[11]'
      value: '''''Because no one was supposed to be at school that late.'''''
      objectReference: {fileID: 0}
    m_RemovedComponents: []
    m_RemovedGameObjects: []
    m_AddedGameObjects: []
    m_AddedComponents: []
  m_SourcePrefab: {fileID: 100100000, guid: 3fb73214af6f28a4f8712c4bda6ebe9f, type: 3}
